{
  "name": "voxtype-meeting",
  "version": "0.1.0",
  "description": "Plugin Obsidian pour piloter les réunions Voxtype et injecter la transcription",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "obsidian": "^1.7.2",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0"
  }
}
